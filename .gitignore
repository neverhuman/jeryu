/target

# Proof-scoped control plane generated outputs
/.witness/
/agent-map.json
/test-map.json
/aer-findings.json
/vrc-plan.json
/.jeryu/git-mirror-events.jsonl

# LaTeX build byproducts; paper sources, screenshots, and final PDFs are tracked.
/paper/*.aux
/paper/*.bbl
/paper/*.blg
/paper/*.log
# jankurai scaffold .gitignore
# Keep Jankurai receipts local without hiding the rest of target/.
target/jankurai/
.jankurai/

# Fixture project build artifacts (self-contained workspace).
tests/fixtures/fixture_project/target/

# CI test evidence (generated per-run).
target/ci-evidence/
target/ci-screenshots/

# Evidence Gate / autonomous-delivery secret material.
# .jeryu/autonomy/keys/ holds ed25519 signing material at runtime; only the
# .gitkeep placeholder is tracked. Belt-and-suspenders pattern matching
# any future env/secret file dropped here.
.jeryu/autonomy/keys/*
!.jeryu/autonomy/keys/.gitkeep
.jeryu/autonomy/flags/*
!.jeryu/autonomy/flags/.gitkeep

# Server-local repo sidecar config. These files can contain hostnames and
# backup targets for one machine and must not become repo policy.
.jeryu/local/

# Release-ready receipts are generated by CI/local lanes.
.jeryu/release-ready/receipts/

# Local secret material — never commit.
*.env
*.env.local
llm.env
~/.jeryu/secrets/
